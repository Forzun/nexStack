generator client {
  provider = "prisma-client"
  output = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String      @id    @default(uuid())
  username       String      @unique
  password       String
  website        Website[]
}

model Website { 
  id              String       @id    @default(uuid())
  url             String       
  time_added       DateTime
  user_id         String
  user            User         @relation(fields: [user_id], references: [id])
  tick            WebsiteTick[]
  region          Region[]
}

model Region { 
  id              String        @id    @default(uuid())
  name            String
  website_id      String
  website          Website      @relation(fields: [website_id] , references: [id]) 
}

model WebsiteTick { 
  id                String         @id     @default(ulid())
  response_time     Int
  website_id        String
  createdAt         DateTime      @default(now())
  status            WebsiteRegion
  website           Website       @relation(fields: [website_id] , references: [id])
}

enum WebsiteRegion { 
  UP 
  DOWN 
  UNKNOWN
}